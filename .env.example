# ============================================
# Maceration IoT Dashboard — Environment Variables
# Copy this file to `.env` in the backend/ folder (or project root,
# depending on how you configure dotenv) and fill in real values.
# NEVER commit the actual `.env` file.
# ============================================

# --- Server ---
PORT=4000
NODE_ENV=development

# --- Database (PostgreSQL) ---
DATABASE_URL=postgres://username:password@localhost:5432/maceration_iot

# --- Auth ---
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# --- MQTT Broker (Mosquitto) ---
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_ADMIN_USER=backend_admin
MQTT_ADMIN_PASS=change-this-password

# --- Frontend (used by frontend build, if needed) ---
VITE_API_BASE_URL=http://localhost:4000/api/v1
VITE_SOCKET_URL=http://localhost:4000
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
